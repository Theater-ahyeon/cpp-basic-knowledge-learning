{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "(gdb) 调试当前文件 (build/)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:\\mingw\\mingw64\\mingw64\\bin\\gdb.exe",
      "preLaunchTask": "C/C++: g++.exe 生成活动文件 (build/)",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}
